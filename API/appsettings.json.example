{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_NEON_HOST.neon.tech;Database=neondb;Port=5432;User Id=YOUR_NEON_USER;Password=YOUR_NEON_PASSWORD;SslMode=Require;"
  },
  "TokenKey": "your_super_secret_jwt_key_at_least_64_characters_long_for_security",
  "CloudinarySettings": {
    "CloudName": "your_cloudinary_cloud_name",
    "ApiKey": "your_cloudinary_api_key",
    "ApiSecret": "your_cloudinary_api_secret"
  }
}
